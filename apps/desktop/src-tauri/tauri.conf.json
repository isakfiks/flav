{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flav",
  "mainBinaryName": "flav",
  "version": "0.0.0",
  "identifier": "com.flav.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:desktop:ui",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "flav",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 620,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ]
  }
}
